# Required for OpenAI-based agents
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=semiconductor-langgraph-agent
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_WORKSPACE_ID=

# Runtime options
ENABLE_WEB_SEARCH=true
ENABLE_DENSE_RAG=true
USE_LLM_PLANNING=false
USE_LLM_SUPERVISOR_REVIEW=true
TRL_LLM_MAX_WORKERS=4

# Output and reference paths
OUTPUT_DIR=outputs
RESEARCH_REFERENCE_DIR=reference/research
TRL_REFERENCE_DIR=reference/trl

# Retrieval configuration
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large-instruct
EMBEDDING_DEVICE=cpu

# External search integrations
SERPAPI_API_KEY=
OPENALEX_EMAIL=you@example.com
# OPENALEX_MAILTO=you@example.com
OPENALEX_API_KEY=

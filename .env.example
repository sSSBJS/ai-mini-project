# Required when using LLM planning or LangChain OpenAI integrations
OPENAI_API_KEY=

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=semiconductor-langgraph-agent
# Optional for self-hosted / EU region
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_WORKSPACE_ID=

# Runtime options
OPENAI_MODEL=gpt-4o-mini
ENABLE_WEB_SEARCH=false
USE_LLM_PLANNING=false

# Output and reference paths
OUTPUT_DIR=outputs
RESEARCH_REFERENCE_DIR=reference/research
TRL_REFERENCE_DIR=reference/trl

# Retrieval configuration
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large-instruct
